  "patchDiff": "diff --git a/src/parse-transport-mode.ts b/src/parse-transport-mode.ts\nindex cbbcd5f16b20e4460b8f942594fa1c0f12a68b3d..dbbdc4ecf14216481db74cd360db09e7b1ecf54b 100644\n--- a/src/parse-transport-mode.ts\n+++ b/src/parse-transport-mode.ts\n@@ -1,8 +1,10 @@\n export type TransportMode = \"direct\" | \"relay\";\n \n export function parseTransportMode(value: string): TransportMode | null {\n-  if (value === \"direct\" || value === \"relay\") {\n-    return value;\n+  const normalizedValue = value.trim();\n+\n+  if (normalizedValue === \"direct\" || normalizedValue === \"relay\") {\n+    return normalizedValue;\n   }\n   return null;\n }\ndiff --git a/tests/parse-transport-mode.test.ts b/tests/parse-transport-mode.test.ts\nindex 4acb9e544456420f68b09dc2dd268c0131e1bb18..c0ee287ad44d2f8d33e4af33fdfc76298960e594 100644\n--- a/tests/parse-transport-mode.test.ts\n+++ b/tests/parse-transport-mode.test.ts\n@@ -7,8 +7,14 @@ describe(\"parseTransportMode\", () => {\n     expect(parseTransportMode(\"relay\")).toBe(\"relay\");\n   });\n \n+  it(\"ignores boundary whitespace from configuration input\", () => {\n+    expect(parseTransportMode(\"  direct\\n\")).toBe(\"direct\");\n+    expect(parseTransportMode(\"\\trelay \")).toBe(\"relay\");\n+  });\n+\n   it(\"rejects unsupported values\", () => {\n     expect(parseTransportMode(\"proxy\")).toBeNull();\n     expect(parseTransportMode(\"DIRECT\")).toBeNull();\n+    expect(parseTransportMode(\" direct mode \")).toBeNull();\n   });\n });\n",
