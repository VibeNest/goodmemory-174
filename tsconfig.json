{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "allowImportingTsExtensions": false,
    "types": ["bun"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "goodmemory": ["./src/index.ts"],
      "goodmemory/ai-sdk": ["./src/ai-sdk/index.ts"],
      "goodmemory/host": ["./src/host/index.ts"]
    }
  },
  "include": ["src", "tests", "scripts"],
  "exclude": ["tests/consumers/reference-package-smoke/smoke-types.ts"]
}
