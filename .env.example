# Local Postgres integration tests
GOODMEMORY_TEST_POSTGRES_URL=postgres://postgres:password@localhost:5432/goodmemory_test

# Optional default runtime storage resolution
# GOODMEMORY_STORAGE_PROVIDER=postgres
# GOODMEMORY_STORAGE_URL=postgres://postgres:password@localhost:5432/goodmemory

# Optional eval model configuration
# GOODMEMORY_EVAL_PROVIDER=openai
# GOODMEMORY_EVAL_MODEL=gpt-5
# GOODMEMORY_EVAL_API_KEY=your-api-key
# GOODMEMORY_EVAL_BASE_URL=https://openrouter.ai/api/v1
# GOODMEMORY_EVAL_MAX_CONCURRENCY=2

# Optional judge model configuration
# GOODMEMORY_JUDGE_PROVIDER=openai
# GOODMEMORY_JUDGE_MODEL=gpt-5
# GOODMEMORY_JUDGE_API_KEY=your-api-key
# GOODMEMORY_JUDGE_BASE_URL=https://openrouter.ai/api/v1

# Optional provider-backed memory eval configuration
# GOODMEMORY_EMBEDDING_PROVIDER=openai
# GOODMEMORY_EMBEDDING_MODEL=text-embedding-3-small
# GOODMEMORY_EMBEDDING_API_KEY=your-api-key
# GOODMEMORY_EMBEDDING_BASE_URL=https://openrouter.ai/api/v1

# Optional local SQLite runtime guardrails
# GOODMEMORY_SQLITE_CUSTOM_LIBRARY_PATH=/opt/homebrew/opt/sqlite/lib/libsqlite3.dylib
# GOODMEMORY_SQLITE_VECTOR_EXTENSION_PATH=/opt/sqlite/vector0.dylib,/opt/sqlite/vss0.dylib
# GOODMEMORY_SQLITE_VECTOR_EXTENSION_ENTRYPOINT=sqlite3_vector_init
# GOODMEMORY_SQLITE_VECTOR_SEARCH_FUNCTION=vss_inner_product
# GOODMEMORY_SQLITE_VECTOR_MODE=prefer

# GOODMEMORY_ASSISTED_EXTRACTOR_PROVIDER=openai
# GOODMEMORY_ASSISTED_EXTRACTOR_MODEL=openai/gpt-4o-mini
# GOODMEMORY_ASSISTED_EXTRACTOR_API_KEY=your-api-key
# GOODMEMORY_ASSISTED_EXTRACTOR_BASE_URL=https://openrouter.ai/api/v1

# Phase-scoped recall router provider configuration
# GOODMEMORY_RECALL_ROUTER_PROVIDER=openai
# GOODMEMORY_RECALL_ROUTER_MODEL=openai/gpt-4o-mini
# GOODMEMORY_RECALL_ROUTER_API_KEY=your-api-key
# GOODMEMORY_RECALL_ROUTER_BASE_URL=https://openrouter.ai/api/v1
