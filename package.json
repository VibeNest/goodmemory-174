{
  "name": "goodmemory",
  "version": "0.2.1",
  "description": "Memory layer for chat, copilot, and agent applications.",
  "license": "MIT",
  "homepage": "https://github.com/hjqcan/GoodMemory#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hjqcan/GoodMemory.git"
  },
  "bugs": {
    "url": "https://github.com/hjqcan/GoodMemory/issues"
  },
  "keywords": [
    "agents",
    "ai",
    "bun",
    "copilot",
    "llm",
    "memory",
    "node",
    "typescript"
  ],
  "type": "module",
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "LICENSE",
    "README.md",
    "README.zh-CN.md",
    "dist",
    "docs",
    "package.json",
    "scripts/goodmemory-cli.js",
    "scripts/goodmemory-cli.ts",
    "scripts/goodmemory-http-bridge.js",
    "scripts/goodmemory-http-bridge.ts",
    "scripts/goodmemory-mcp.js",
    "scripts/goodmemory-mcp.ts",
    "src"
  ],
  "bin": {
    "goodmemory": "./scripts/goodmemory-cli.js",
    "goodmemory-http-bridge": "./scripts/goodmemory-http-bridge.js",
    "goodmemory-mcp": "./scripts/goodmemory-mcp.js"
  },
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./host": {
      "types": "./dist/host/index.d.ts",
      "import": "./dist/host/index.js"
    },
    "./ai-sdk": {
      "types": "./dist/ai-sdk/index.d.ts",
      "import": "./dist/ai-sdk/index.js"
    },
    "./http": {
      "types": "./dist/http/index.d.ts",
      "import": "./dist/http/index.js"
    },
    "./runtime-kit": {
      "types": "./dist/runtime-kit/index.d.ts",
      "import": "./dist/runtime-kit/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build:js": "bun run scripts/build-package.ts",
    "build:types": "bunx tsc -p tsconfig.package.json",
    "build": "bun run clean && bun run build:js && bun run build:types",
    "test": "bun test",
    "test:all": "bun --config=bunfig.all.toml test tests third-party",
    "test:unit": "bun test tests/unit",
    "test:integration": "bun test tests/integration",
    "test:scenarios": "bun test tests/scenarios",
    "test:eval": "bun test tests/eval",
    "test:coverage": "bun test --coverage --coverage-reporter=lcov --coverage-reporter=text && bun run scripts/check-coverage.ts",
    "test:ci": "bun run typecheck && bun run test:coverage",
    "test:watch": "bun test --watch",
    "typecheck": "bunx tsc --noEmit",
    "goodmemory": "bun run scripts/goodmemory-cli.ts",
    "goodmemory:http-bridge": "bun run scripts/goodmemory-http-bridge.ts",
    "goodmemory:mcp": "bun run scripts/goodmemory-mcp.ts",
    "fixtures:generate": "bun run scripts/generate-eval-fixtures.ts",
    "example:chat": "bun run examples/basic-chat.ts",
    "example:coding-agent": "bun run examples/coding-agent.ts",
    "example:ai-sdk-server": "bun run examples/plain-ai-sdk-server.ts",
    "example:express-chat": "bun run examples/express-chat-server.ts",
    "example:fastify-chat": "bun run examples/fastify-chat-server.ts",
