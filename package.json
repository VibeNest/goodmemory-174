{
  "name": "goodmemory",
  "version": "0.1.0-rc.1",
  "description": "Bun-only memory layer for chat, copilot, and agent applications.",
  "license": "MIT",
  "homepage": "https://github.com/hjqcan/GoodMemory#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hjqcan/GoodMemory.git"
  },
  "bugs": {
    "url": "https://github.com/hjqcan/GoodMemory/issues"
  },
  "keywords": [
    "agents",
    "ai",
    "bun",
    "copilot",
    "llm",
    "memory"
  ],
  "type": "module",
  "packageManager": "bun@1.3.0",
  "engines": {
    "bun": ">=1.3.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "LICENSE",
    "README.md",
    "docs",
    "package.json",
    "scripts/goodmemory-cli.ts",
    "src"
  ],
  "bin": {
    "goodmemory": "./scripts/goodmemory-cli.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./cli": "./src/cli.ts",
    "./host": "./src/host/index.ts",
    "./ai-sdk": "./src/ai-sdk/index.ts"
  },
  "scripts": {
    "test": "bun test",
    "test:all": "bun --config=bunfig.all.toml test tests third-party",
    "test:unit": "bun test tests/unit",
    "test:integration": "bun test tests/integration",
    "test:scenarios": "bun test tests/scenarios",
    "test:eval": "bun test tests/eval",
    "test:coverage": "bun test --coverage --coverage-reporter=lcov --coverage-reporter=text && bun run scripts/check-coverage.ts",
    "test:ci": "bun run typecheck && bun run test:coverage",
    "test:watch": "bun test --watch",
    "typecheck": "bunx tsc --noEmit",
    "goodmemory": "bun run scripts/goodmemory-cli.ts",
    "fixtures:generate": "bun run scripts/generate-eval-fixtures.ts",
    "example:chat": "bun run examples/basic-chat.ts",
    "example:coding-agent": "bun run examples/coding-agent.ts",
    "example:vercel-ai": "bun run examples/vercel-ai-chat.ts",
    "example:host-claude": "bun run examples/host-claude-artifacts.ts",
    "example:host-codex": "bun run examples/host-codex-handoff.ts",
    "eval:smoke": "bun run scripts/run-eval.ts --mode=smoke",
    "eval:fallback": "bun run scripts/run-eval.ts --mode=fallback",
    "eval:phase-16": "bun run scripts/run-phase-16-eval.ts",
    "eval:phase-17": "bun run scripts/run-phase-17-eval.ts",
    "eval:phase-17-live-memory": "bun run scripts/run-phase-17-live-memory.ts",
    "eval:phase-21": "bun run scripts/run-phase-21-eval.ts",
    "eval:phase-21-live-memory": "bun run scripts/run-phase-21-live-memory.ts",
    "eval:phase-22": "bun run scripts/run-phase-22-eval.ts",
    "eval:phase-22-live-memory": "bun run scripts/run-phase-22-live-memory.ts",
    "eval:phase-23": "bun run scripts/run-phase-23-eval.ts",
    "eval:phase-23-live-memory": "bun run scripts/run-phase-23-live-memory.ts",
    "eval:phase-24": "bun run scripts/run-phase-24-eval.ts",
    "eval:phase-24-live-memory": "bun run scripts/run-phase-24-live-memory.ts",
    "eval:phase-25": "bun run scripts/run-phase-25-eval.ts",
    "eval:phase-25-live-memory": "bun run scripts/run-phase-25-live-memory.ts",
    "eval:phase-27": "bun run scripts/run-phase-27-eval.ts",
    "eval:phase-27-live-memory": "bun run scripts/run-phase-27-live-memory.ts",
    "eval:phase-30": "bun run scripts/run-phase-30-eval.ts",
    "eval:phase-30-live-memory": "bun run scripts/run-phase-30-live-memory.ts",
    "eval:phase-31": "bun run scripts/run-phase-31-eval.ts",
    "eval:phase-31-live-memory": "bun run scripts/run-phase-31-live-memory.ts",
    "gate:phase-18": "bun run scripts/run-phase-18-gate.ts",
    "gate:phase-19-reviewer": "bun run scripts/run-phase-19-reviewer-gate.ts",
    "gate:phase-19-maintenance": "bun run scripts/run-phase-19-maintenance-gate.ts",
    "gate:phase-20": "bun run scripts/run-phase-20-gate.ts",
    "gate:phase-21": "bun run scripts/run-phase-21-gate.ts",
    "gate:phase-22": "bun run scripts/run-phase-22-gate.ts",
    "gate:phase-23": "bun run scripts/run-phase-23-gate.ts",
    "gate:phase-24": "bun run scripts/run-phase-24-gate.ts",
    "gate:phase-25": "bun run scripts/run-phase-25-gate.ts",
    "gate:phase-26": "bun run scripts/run-phase-26-gate.ts",
    "gate:phase-27": "bun run scripts/run-phase-27-gate.ts",
    "gate:phase-28": "bun run scripts/run-phase-28-gate.ts",
    "gate:phase-29": "bun run scripts/run-phase-29-gate.ts",
    "gate:phase-30": "bun run scripts/run-phase-30-gate.ts",
    "gate:phase-31": "bun run scripts/run-phase-31-gate.ts",
    "release:rc-dry-run": "bun run scripts/run-phase-29-rc-dry-run.ts",
    "eval:live": "bun run scripts/run-eval.ts --mode=live",
    "eval:live-memory": "bun run scripts/run-eval.ts --mode=live-memory",
    "eval:live-auto-memory": "bun run scripts/run-eval.ts --mode=live-auto-memory",
    "eval:live-provider-memory": "bun run scripts/run-eval.ts --mode=live-provider-memory",
    "eval:summary": "bun run scripts/summarize-eval.ts"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.64",
    "@ai-sdk/openai": "^3.0.49",
    "@ai-sdk/openai-compatible": "^2.0.40",
    "ai": "^6.0.143",
    "sqlite-vss": "0.1.2",
    "zod": "^4.3.6"
  }
}
