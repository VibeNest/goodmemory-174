      "conditioned_jargon_avoidance.json": {
        "scorer": "text_behavior_judge",
        "feedbackSignal": "Explain this concept with a simple analogy and avoid the term API.",
        "smokeAssertions": {
          "requiredKeywords": [
            "like"
          ],
          "forbiddenPhrases": [
            "API"
          ]
        }
      },
      "conditioned_protocol_preference.json": {
